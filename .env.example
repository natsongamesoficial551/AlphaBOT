# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=seu_token_aqui
GUILD_ID=id_do_seu_servidor

# ─── Auth Próprio (substitui KeyAuth — GRATUITO) ─────────────────────────────
# Chave secreta usada pelo bot para criar contas via API
# Coloque esse mesmo valor no MyAuth.cs no campo "secret"
AUTH_BOT_SECRET=alpha_xit_bot_2024

# Salt para hash de senhas (mude para algo único seu!)
AUTH_SALT=alphaxitsalt2024

# ID do canal Discord onde pedidos pagos aparecem para aprovação do staff
AUTH_CHANNEL_ID=SEU_CANAL_ID_AQUI

# ─── PIX (para planos pagos) ──────────────────────────────────────────────────
PIX_KEY=sua_chave_pix
PIX_NAME=Seu Nome

# ─── Banco de dados ───────────────────────────────────────────────────────────
# No Render, use um Disk montado em /data e configure:
# DB_PATH=/data/alphabot.db
# (deixe vazio para usar ./data/alphabot.db localmente)
DB_PATH=

# ─── Render ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Auth: canal de suporte para planos pagos ─────────────────────────────────
# Nome do canal onde o usuário é redirecionado ao escolher plano pago
AUTH_SUPORTE_CANAL=❓・auth-id-duvidas
