# ─────────────────────────────────────────
# AlphaBot — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ─────────────────────────────────────────

# Token do bot (Discord Developer Portal)
DISCORD_TOKEN=seu_token_aqui

# ID do seu servidor Discord
GUILD_ID=id_do_servidor_aqui

# Chave PIX para receber pagamentos
PIX_KEY=sua_chave_pix_aqui

# Nome que aparece no embed do PIX
PIX_NAME=Alpha Xit

# URL do canal do YouTube (ex: https://www.youtube.com/@seucanal)
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@seucanal

# Intervalo de checagem YouTube em minutos (padrão 10)
YOUTUBE_CHECK_INTERVAL=10

# Caminho do banco SQLite (não altere no Render, use /data/alphabot.db)
DB_PATH=./data/alphabot.db

# URL do seu serviço no Render (para não hibernar)
# Ex: https://alphabot.onrender.com
AUTO_PING=https://seubot.onrender.com

# ─────────────────────────────────────────
# KEYAUTH
# ─────────────────────────────────────────

# ID do proprietário da conta KeyAuth
KEYAUTH_OWNER_ID=NHztIH6Srm

# Segredo do aplicativo KeyAuth
KEYAUTH_APP_SECRET=6da41d14346b3c8aeae7a969fda4cdabf12dc25e1a80dcdb6292624a49a013bb

# Nome do aplicativo (exatamente como no painel)
KEYAUTH_APP_NAME=Borgesnatan09's Application

# Versão do aplicativo
KEYAUTH_APP_VERSION=1.0
