# ─── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=seu_token_aqui
GUILD_ID=id_do_seu_servidor

# ─── Dono do servidor (OBRIGATÓRIO para o sistema de compra Pix) ───────────────
# Coloque aqui o SEU ID do Discord.
# Você receberá os pedidos de compra na sua DM e poderá aprovar ou reprovar.
# Para descobrir seu ID: Configurações → Avançado → Modo Desenvolvedor → clique direito no seu perfil
OWNER_ID=SEU_DISCORD_ID_AQUI

# ─── Canais ───────────────────────────────────────────────────────────────────
# Canal onde fica o embed público "Solicitar Auth Key"
AUTH_CHANNEL_ID=ID_DO_CANAL_AUTH

# Canal privado do staff onde chegam as solicitações para aprovar/reprovar
STAFF_CHANNEL_ID=ID_DO_CANAL_STAFF

# ─── Auth Key System ──────────────────────────────────────────────────────────
AUTH_BOT_SECRET=alpha_xit_bot_2024
AUTH_SALT=alphaxitsalt2024

# ─── PIX ──────────────────────────────────────────────────────────────────────
# Chave Pix do recebedor (CPF, telefone, e-mail ou chave aleatória)
PIX_KEY=sua_chave_pix

# Nome do recebedor (aparece no QR Code e na DM do comprador — máx. 25 chars)
PIX_NAME=Seu Nome

# Cidade do recebedor (sem acentos — máx. 15 chars, ex: Sao Paulo, Rio de Janeiro)
PIX_CITY=Sao Paulo

# ─── Banco de dados (OBRIGATÓRIO no Render) ───────────────────────────────────
# Opção 1: Turso (recomendado — persiste na nuvem)
TURSO_URL=libsql://seu-banco.turso.io
TURSO_TOKEN=eyJ...

# Opção 2: SQLite local (some no Render ao reiniciar — use só para testes)
# 1. Crie um Disk em /data no Render Dashboard
# 2. Defina DB_PATH=/data/alphabot.db
DB_PATH=/data/alphabot.db

# ─── Render ───────────────────────────────────────────────────────────────────
PORT=3000
