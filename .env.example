# ── Discord ───────────────────────────────────────────────
DISCORD_TOKEN=seu_token_aqui
GUILD_ID=id_do_servidor
CLIENT_ID=id_do_bot

# ── Auth System ────────────────────────────────────────────
AUTH_CHANNEL_ID=id_do_canal_auth
STAFF_CHANNEL_ID=id_do_canal_staff
AUTH_SALT=uma_string_aleatoria_longa_aqui_mude_isso

# ── Segurança da API (OBRIGATÓRIO mudar em produção!) ──────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOT_SECRET=gere_um_valor_aleatorio_aqui
SESSION_SECRET=gere_outro_valor_aleatorio_aqui
INTERNAL_TOKEN=mais_um_valor_aleatorio_aqui

# ── PIX (chave local para geração de QR Code e Copia e Cola) ──
# Esses dados são usados para gerar o QR Code e o Pix copia e cola diretamente no bot
PIX_KEY=18691716754
PIX_NAME=Alpha Xit
PIX_CITY=Sao Paulo

# ── API Promisse (opcional — para confirmação automática de pagamento) ─────────
# Se configurada, o bot confirma o pagamento automaticamente via polling.
# Se NÃO configurada, o bot ainda gera QR Code e Pix copia e cola normalmente,
# mas a confirmação do pedido precisará ser feita manualmente pelo admin.
# Obtenha sua chave em: https://promisse.com.br
PROMISSE_API_KEY=sua_chave_api_promisse_aqui

# ── Owner ──────────────────────────────────────────────────
# ID do Discord do dono — recebe notificações de pedidos na DM
OWNER_ID=seu_id_discord_aqui

# ── Canais de Produto (opcional — sobrescreve o padrão no código) ───
CANAL_PAGO_ID=id_do_canal_produtos_pagos
CANAL_FREE_ID=id_do_canal_produtos_gratuitos

# ── Banco de Dados (Turso — recomendado para produção) ─────
TURSO_URL=libsql://seu-banco.turso.io
TURSO_TOKEN=seu_token_turso
