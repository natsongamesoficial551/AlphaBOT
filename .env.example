# ── Discord ───────────────────────────────────────────────
DISCORD_TOKEN=seu_token_aqui
GUILD_ID=id_do_servidor
OWNER_ID=seu_id_discord_aqui

# ── API Promisse (Pagamento Automático) ───────────────────
# Obtenha sua chave em: https://promisse.com.br
PROMISSE_API_KEY=sua_chave_api_promisse_aqui

# ── Banco de Dados (Turso — recomendado para produção) ─────
# Se não preencher, o bot usará um arquivo local (data/alphabot.db)
TURSO_URL=libsql://seu-banco.turso.io
TURSO_TOKEN=seu_token_turso
